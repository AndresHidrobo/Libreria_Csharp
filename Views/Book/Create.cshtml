@model Libreria.Models.Book
@{
    ViewData["Title"] = "Crear Libro";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="mb-1">Crear Libro</h2>
        <p class="text-muted mb-0">Registra un nuevo libro en el catálogo.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                    }

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Título</label>
                        <input asp-for="Title" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Descripción</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label">Autor</label>
                        <input asp-for="Author" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Editorial" class="form-label">Editorial</label>
                        <input asp-for="Editorial" class="form-control" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
