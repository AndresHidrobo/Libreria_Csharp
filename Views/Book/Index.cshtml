@model IEnumerable<Libreria.Models.Book>
@{
    ViewData["Title"] = "Libros";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="mb-1">Libros</h2>
        <p class="text-muted mb-0">Administra el catálogo de libros disponible.</p>
    </div>
    <a asp-action="Create" asp-controller="Book" class="btn btn-primary">Crear nuevo libro</a>
</div>

@if (TempData["Message"] != null )
{
    if (TempData["Success"] is true)
    {
        <div class="alert alert-success">
            @TempData["Message"]
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            @TempData["Message"]
        </div>
    }
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm table-striped table-hover align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>TITULO</th>
                    <th>AUTOR</th>
                    <th>EDITORIAL</th>
                    <th>ACCIONES</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td>@book.Id</td>
                        <td>@book.Title</td>
                        <td>@book.Author</td>
                        <td>@book.Editorial</td>
                        <td>
                            <form asp-action="Destroy" asp-controller="Book" asp-route-id="@book.Id" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <a asp-action="Show" asp-controller="Book" asp-route-id="@book.Id" class="btn btn-sm btn-info">Detalles</a>
                                <a asp-action="Edit" asp-controller="Book" asp-route-id="@book.Id" class="btn btn-sm btn-warning">Editar</a>
                                <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
