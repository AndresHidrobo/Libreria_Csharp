@model Libreria.Models.Book
@{
    ViewData["Title"] = "Detalle Libro";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="mb-1">Detalle de Libro</h2>
        <p class="text-muted mb-0">Consulta la información registrada del libro.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Id</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4">Título</dt>
                    <dd class="col-sm-8">@Model.Title</dd>

                    <dt class="col-sm-4">Descripción</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Autor</dt>
                    <dd class="col-sm-8">@Model.Author</dd>

                    <dt class="col-sm-4">Editorial</dt>
                    <dd class="col-sm-8">@Model.Editorial</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
