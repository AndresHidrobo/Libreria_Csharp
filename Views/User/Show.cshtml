@model Libreria.Models.User
@{
    ViewData["Title"] = "Detalle Usuario";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="mb-1">Detalle de Usuario</h2>
        <p class="text-muted mb-0">Consulta la información registrada del usuario.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Id</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Correo</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Contraseña</dt>
                    <dd class="col-sm-8">@Model.Password</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
