@{
    ViewData["Title"] = "Inicio";
}

<div class="hero-panel">
    <div>
        <h1 class="display-5 fw-bold mb-2">Librería Hidrobo</h1>
        <p class="lead mb-0">Selecciona un módulo para administrar usuarios, libros y préstamos.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h3 class="h5">Usuarios</h3>
                <p class="text-muted">Gestiona altas, consulta, edición y eliminación de usuarios.</p>
                <a asp-controller="User" asp-action="Index" class="btn btn-primary">Ir a usuarios</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h3 class="h5">Libros</h3>
                <p class="text-muted">Administra el catálogo completo de libros del sistema.</p>
                <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Ir a libros</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h3 class="h5">Préstamos</h3>
                <p class="text-muted">Consulta y actualiza los préstamos asociados a usuarios y libros.</p>
                <a asp-controller="Record" asp-action="Index" class="btn btn-primary">Ir a préstamos</a>
            </div>
        </div>
    </div>
</div>
