@model Libreria.Models.Record
@{
    ViewData["Title"] = "Detalle Préstamo";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="mb-1">Detalle de Préstamo</h2>
        <p class="text-muted mb-0">Consulta la información completa del préstamo.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Id</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4">Usuario</dt>
                    <dd class="col-sm-8">@(Model.User?.Name ?? $"Usuario #{Model.UserId}")</dd>

                    <dt class="col-sm-4">Libro</dt>
                    <dd class="col-sm-8">@(Model.Book?.Title ?? $"Libro #{Model.BookId}")</dd>

                    <dt class="col-sm-4">Fecha</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>

                    <dt class="col-sm-4">Activo</dt>
                    <dd class="col-sm-8">@(Model.IsActive ? "Sí" : "No, finalizado")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
